{
  "name": "stablepay-agentpay-dev",
  "version": "0.3.8",
  "type": "module",
  "description": "StablePay wallet, client-side DID registration, OWS/local signing, and payment tools for OpenClaw.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stablepay/stablepay-openclaw-plugin.git"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.1",
      "minGatewayVersion": "2026.3.1"
    },
    "build": {
      "openclawVersion": "2026.3.1",
      "pluginSdkVersion": "2026.3.1"
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@noble/curves": "^1.4.2",
    "@open-wallet-standard/core": "^1.1.2",
    "@sinclair/typebox": "^0.34.41",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.1"
  },
  "devDependencies": {
    "@types/bs58": "^4.0.4",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
